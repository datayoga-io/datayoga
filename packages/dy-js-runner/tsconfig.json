{
  "compilerOptions": {
    "module": "commonjs",
    "target": "esnext",
    "baseUrl": ".",
    "moduleResolution": "node",
    "declaration": true,
    "declarationDir": "./dist/types",
    "outDir": "dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": false,
    "allowJs": true,
    "types": ["node"],
    "lib": ["esnext", "scripthost"]
  },
  "include": ["**/*.ts"]
}
