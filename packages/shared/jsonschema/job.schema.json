{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "title": "Job",
  "description": "representation of an ETL job",
  "examples": [
    {
      "steps": [
        {
          "id": "extract_csv",
          "uses": "extract",
          "properties": {
            "source": "employee"
          }
        },
        {
          "id": "load_snowflake",
          "uses": "load",
          "properties": {
            "table_name": "tab"
          },
          "inputs": {
            "df": "extract/df"
          }
        }
      ]
    }
  ],
  "required": ["steps"],
  "properties": {
    "runs-on": {
      "type": "string",
      "description": "Which runner to use to process this pipeline. `pyspark` uses pyspark with the dataframe API. `pysql` uses Python and SQLAlchemy and is suited to an ELT approach. `jssql` uses Javascript and Knex and is suited to an ELT approach",
      "enum": ["pyspark", "pysql", "jssql"]
    },
    "steps": {
      "type": "array",
      "description": "List of blocks. These will be run in order, where each step's output is the next step's input, unless the 'inputs' clause is specified",
      "default": [],
      "examples": [
        [
          {
            "id": "extract_csv",
            "uses": "extract",
            "properties": {
              "source": "employee"
            }
          },
          {
            "id": "load_snowflake",
            "uses": "load",
            "properties": {
              "table_name": "tab"
            },
            "inputs": {
              "df": "extract/df"
            }
          }
        ]
      ],
      "items": {
        "$ref": "step"
      }
    }
  }
}
